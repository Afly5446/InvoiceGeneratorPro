<Application x:Class="InvoiceGeneratorPro.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <!-- Палитра -->
    <Color x:Key="ColorInk">#0F172A</Color>
    <Color x:Key="ColorMuted">#64748B</Color>
    <Color x:Key="ColorLine">#E2E8F0</Color>
    <Color x:Key="ColorSurface">#FFFFFF</Color>
    <Color x:Key="ColorCanvas">#F1F5F9</Color>
    <Color x:Key="ColorAccent">#4F46E5</Color>
    <Color x:Key="ColorAccentDark">#3730A3</Color>
    <Color x:Key="ColorAccentSoft">#EEF2FF</Color>
    <Color x:Key="ColorDanger">#DC2626</Color>
    <Color x:Key="ColorDangerSoft">#FEF2F2</Color>

    <SolidColorBrush x:Key="BrushInk" Color="{StaticResource ColorInk}"/>
    <SolidColorBrush x:Key="BrushMuted" Color="{StaticResource ColorMuted}"/>
    <SolidColorBrush x:Key="BrushLine" Color="{StaticResource ColorLine}"/>
    <SolidColorBrush x:Key="BrushSurface" Color="{StaticResource ColorSurface}"/>
    <SolidColorBrush x:Key="BrushCanvas" Color="{StaticResource ColorCanvas}"/>
    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="BrushAccentDark" Color="{StaticResource ColorAccentDark}"/>
    <SolidColorBrush x:Key="BrushAccentSoft" Color="{StaticResource ColorAccentSoft}"/>
    <SolidColorBrush x:Key="BrushDanger" Color="{StaticResource ColorDanger}"/>
    <SolidColorBrush x:Key="BrushDangerSoft" Color="{StaticResource ColorDangerSoft}"/>

    <LinearGradientBrush x:Key="BrushAppBackground" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#EEF2FF" Offset="0"/>
      <GradientStop Color="#F8FAFC" Offset="0.45"/>
      <GradientStop Color="#F1F5F9" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BrushHeader" StartPoint="0,0" EndPoint="1,0">
      <GradientStop Color="#312E81" Offset="0"/>
      <GradientStop Color="#4F46E5" Offset="0.55"/>
      <GradientStop Color="#6366F1" Offset="1"/>
    </LinearGradientBrush>

    <FontFamily x:Key="FontUi">Segoe UI Variable Display, Segoe UI, system-ui</FontFamily>

    <!-- Текст -->
    <Style x:Key="HeroTitle" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
      <Setter Property="FontSize" Value="24"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style x:Key="HeroSubtitle" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Foreground" Value="#C7D2FE"/>
      <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>
    <Style x:Key="PanelTitle" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
      <Setter Property="FontSize" Value="18"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource BrushInk}"/>
    </Style>
    <Style x:Key="SectionTitle" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource BrushMuted}"/>
      <Setter Property="Margin" Value="0,16,0,8"/>
    </Style>
    <Style x:Key="Caption" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="{StaticResource BrushMuted}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="LineHeight" Value="16"/>
    </Style>

    <!-- Подписи полей -->
    <Style x:Key="FormLabel" TargetType="Label">
      <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource BrushInk}"/>
      <Setter Property="Margin" Value="0,10,0,4"/>
      <Setter Property="Padding" Value="0"/>
    </Style>

    <!-- Поле ввода -->
    <Style x:Key="RoundedTextBox" TargetType="TextBox">
      <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Foreground" Value="{StaticResource BrushInk}"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="Margin" Value="0,0,0,2"/>
      <Setter Property="CaretBrush" Value="{StaticResource BrushAccent}"/>
      <Setter Property="SelectionBrush" Value="#C7D2FE"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border x:Name="Bd"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushLine}"
                    BorderThickness="1"
                    CornerRadius="10"
                    SnapsToDevicePixels="True">
              <ScrollViewer x:Name="PART_ContentHost"
                            Focusable="False"
                            HorizontalScrollBarVisibility="Hidden"
                            VerticalScrollBarVisibility="Hidden"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="#C7D2FE"/>
              </Trigger>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                <Setter TargetName="Bd" Property="BorderThickness" Value="1.5"/>
              </Trigger>
              <Trigger Property="Validation.HasError" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrushDanger}"/>
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushDangerSoft}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="TextBox" BasedOn="{StaticResource RoundedTextBox}"/>

    <!-- DatePicker -->
    <Style x:Key="FormDatePicker" TargetType="DatePicker">
      <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Margin" Value="0,0,0,10"/>
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="Background" Value="{StaticResource BrushSurface}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BrushLine}"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Кнопки -->
    <Style x:Key="PrimaryButton" TargetType="Button">
      <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="16,10"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="SnapsToDevicePixels" Value="True"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="b" Property="Background" Value="{StaticResource BrushAccentDark}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="b" Property="Opacity" Value="0.92"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="b" Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
      <Setter Property="Foreground" Value="{StaticResource BrushInk}"/>
      <Setter Property="Background" Value="{StaticResource BrushSurface}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="b"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{StaticResource BrushLine}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="b" Property="Background" Value="{StaticResource BrushAccentSoft}"/>
                <Setter TargetName="b" Property="BorderBrush" Value="#C7D2FE"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="b" Property="Opacity" Value="0.9"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="b" Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DangerOutlineButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
      <Setter Property="Foreground" Value="{StaticResource BrushDanger}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="b"
                    Background="{StaticResource BrushDangerSoft}"
                    BorderBrush="#FECACA"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="b" Property="Background" Value="#FEE2E2"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="b" Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Карточка -->
    <Style x:Key="ElevatedCard" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource BrushSurface}"/>
      <Setter Property="CornerRadius" Value="16"/>
      <Setter Property="BorderBrush" Value="#E8EDF5"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="SnapsToDevicePixels" Value="True"/>
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect BlurRadius="28" ShadowDepth="2" Opacity="0.12" Direction="270" Color="#1E1B4B"/>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Табы -->
    <Style x:Key="PreviewTabControl" TargetType="TabControl">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="PreviewTabItem" TargetType="TabItem">
      <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource BrushMuted}"/>
      <Setter Property="Padding" Value="16,10"/>
      <Setter Property="Margin" Value="0,0,8,0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="Root" Background="Transparent" CornerRadius="10" Padding="{TemplateBinding Padding}">
              <ContentPresenter x:Name="ContentSite" ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{StaticResource BrushAccentSoft}"/>
                <Setter Property="Foreground" Value="{StaticResource BrushAccentDark}"/>
              </Trigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsSelected" Value="False"/>
                  <Condition Property="IsMouseOver" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter TargetName="Root" Property="Background" Value="#F1F5F9"/>
              </MultiTrigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsSelected" Value="True"/>
                  <Condition Property="IsMouseOver" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter TargetName="Root" Property="Background" Value="#E0E7FF"/>
              </MultiTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- DataGrid -->
    <Style x:Key="InvoiceDataGrid" TargetType="DataGrid">
      <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Background" Value="{StaticResource BrushSurface}"/>
      <Setter Property="Foreground" Value="{StaticResource BrushInk}"/>
      <Setter Property="RowBackground" Value="{StaticResource BrushSurface}"/>
      <Setter Property="AlternatingRowBackground" Value="#FAFBFF"/>
      <Setter Property="BorderBrush" Value="{StaticResource BrushLine}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="GridLinesVisibility" Value="Horizontal"/>
      <Setter Property="HorizontalGridLinesBrush" Value="#EEF2F7"/>
      <Setter Property="HeadersVisibility" Value="Column"/>
      <Setter Property="RowHeight" Value="36"/>
      <Setter Property="ColumnHeaderHeight" Value="40"/>
      <Setter Property="SelectionMode" Value="Single"/>
      <Setter Property="SelectionUnit" Value="FullRow"/>
    </Style>

    <Style x:Key="InvoiceDataGridColumnHeader" TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="#F4F6FB"/>
      <Setter Property="Foreground" Value="{StaticResource BrushMuted}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Padding" Value="12,0"/>
      <Setter Property="BorderBrush" Value="{StaticResource BrushLine}"/>
      <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>

    <Style x:Key="InvoiceDataGridCell" TargetType="DataGridCell">
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="DataGridCell">
            <Border Background="{TemplateBinding Background}" BorderThickness="0" Padding="{TemplateBinding Padding}">
              <ContentPresenter VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="{StaticResource BrushAccentSoft}"/>
          <Setter Property="Foreground" Value="{StaticResource BrushAccentDark}"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </Application.Resources>
</Application>
